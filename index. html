<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>HubPkr Ludo</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background-color: #f7ca18; /* Matched to the Hub yellow theme */
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            overflow: hidden;
            touch-action: manipulation;
        }
        #game-container {
            position: relative;
            width: 95vmin;
            max-width: 600px;
            aspect-ratio: 1 / 1;
        }
        canvas {
            width: 100%;
            height: 100%;
            box-shadow: 0px 15px 35px rgba(0,0,0,0.4);
            border-radius: 8px;
            background-color: #eaddcf;
        }
    </style>
</head>
<body>

    <div id="game-container">
        <canvas id="ludoCanvas" width="800" height="800"></canvas>
    </div>

    <script>
        const canvas = document.getElementById('ludoCanvas');
        const ctx = canvas.getContext('2d');

        // 1. GAME STATES & SYSTEM
        let gameState = 'splash'; // 'splash' or 'playing'
        let lastTime = 0;
        let screenShake = { x: 0, y: 0, duration: 0, intensity: 0 };
        let particles = [];

        // 2. PROCEDURAL AUDIO ENGINE (Web Audio API)
        let audioCtx = null;
        function initAudio() {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }

        function playSound(type) {
            if (!audioCtx) return;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);

            const now = audioCtx.currentTime;

            if (type === 'dice') { // Hollow rock rattle
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(120, now);
                osc.frequency.exponentialRampToValueAtTime(40, now + 0.15);
                gain.gain.setValueAtTime(0.3, now);
                gain.gain.linearRampToValueAtTime(0, now + 0.15);
                osc.start(now); osc.stop(now + 0.15);
            } else if (type === 'thud') { // Heavy stone landing slam
                osc.type = 'sine';
                osc.frequency.setValueAtTime(90, now);
                osc.frequency.exponentialRampToValueAtTime(20, now + 0.2);
                gain.gain.setValueAtTime(0.6, now);
                gain.gain.linearRampToValueAtTime(0, now + 0.2);
                osc.start(now); osc.stop(now + 0.2);
            } else if (type === 'capture') { // Intense rock smash
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(300, now);
                osc.frequency.linearRampToValueAtTime(80, now + 0.4);
                gain.gain.setValueAtTime(0.4, now);
                gain.gain.linearRampToValueAtTime(0, now + 0.4);
                osc.start(now); osc.stop(now + 0.4);
            }
        }

        // 3. ASSET PIPELINE
        const images = {
            board: new Image(),
            dice: new Image(),
            logo: new Image()
        };
        images.board.src = 'board.png';
        images.dice.src = 'stone_dice.png';
        images.logo.src = 'logo.jpg';

        // 4. ANIMATED OBJECTS
        let splashAlpha = 0;
        let splashStage = 'fade-in'; // 'fade-in', 'idle', 'fade-out'
        let playButtonScale = 1;
        let playButtonPulse = 0;

        let dice = {
            x: 400, y: 400, size: 80, rotation: 0, scale: 1, 
            isRolling: false, rollTimer: 0, currentFace: 1,
            shakeX: 0, shakeY: 0
        };

        let tokens = [
            { id: 1, color: '#e74c3c', targetX: 160, targetY: 160, currentX: 160, currentY: 160, jumpProgress: 0, scaleX: 1, scaleY: 1, height: 0, shadowBlur: 8, isMoving: false },
            { id: 2, color: '#2ecc71', targetX: 640, targetY: 160, currentX: 640, currentY: 160, jumpProgress: 0, scaleX: 1, scaleY: 1, height: 0, shadowBlur: 8, isMoving: false }
        ];

        // 5. PARTICLE SYSTEM
        class Particle {
            constructor(x, y, color) {
                this.x = x; this.y = y;
                this.vx = (Math.random() - 0.5) * 8;
                this.vy = (Math.random() - 0.5) * 8 - 3;
                this.alpha = 1;
                this.color = color;
                this.size = Math.random() * 6 + 4;
            }
            update(dt) {
                this.x += this.vx; this.y += this.vy;
                this.vy += 0.2; // Gravity simulation
                this.vx *= 0.95; // Friction
                this.alpha -= dt * 1.5;
            }
            draw() {
                ctx.save();
                ctx.globalAlpha = Math.max(0, this.alpha);
                ctx.fillStyle = this.color;
                ctx.fillRect(this.x - this.size/2, this.y - this.size/2, this.size, this.size);
                ctx.restore();
            }
        }

        function triggerSlamEffects(x, y, color) {
            playSound('thud');
            triggerScreenShake(6, 0.15);
            for(let i=0; i<12; i++) particles.push(new Particle(x, y, color === 'stone' ? '#8a8d91' : color));
        }

        function triggerScreenShake(intensity, duration) {
            screenShake.intensity = intensity;
            screenShake.duration = duration;
        }

        // 6. CORE ENGINE UPDATE LOOP (Delta Time Enabled)
        function update(currentTime) {
            if (!lastTime) lastTime = currentTime;
            const dt = (currentTime - lastTime) / 1000;
            lastTime = currentTime;

            // Handle Screen Shake logic
            if (screenShake.duration > 0) {
                screenShake.duration -= dt;
                screenShake.x = (Math.random() - 0.5) * screenShake.intensity;
                screenShake.y = (Math.random() - 0.5) * screenShake.intensity;
            } else {
                screenShake.x = 0; screenShake.y = 0;
            }

            // Update Splash Screen Animations
            if (gameState === 'splash') {
                playButtonPulse += dt * 3;
                playButtonScale = 1 + Math.sin(playButtonPulse) * 0.05;
                if (splashStage === 'fade-in') {
                    splashAlpha += dt * 0.8;
                    if (splashAlpha >= 1) { splashAlpha = 1; splashStage = 'idle'; }
                } else if (splashStage === 'fade-out') {
                    splashAlpha -= dt * 2;
                    if (splashAlpha <= 0) { splashAlpha = 0; gameState = 'playing'; }
                }
            }

            // Update Dice Logic
            if (gameState === 'playing' && dice.isRolling) {
                dice.rollTimer -= dt;
                dice.rotation += dt * 25;
                dice.scale = 1.4 - Math.abs(Math.sin(dice.rollTimer * 10)) * 0.3;
                dice.shakeX = (Math.random() - 0.5) * 10;
                dice.shakeY = (Math.random() - 0.5) * 10;
                if (Math.random() < 0.3) playSound('dice');

                if (dice.rollTimer <= 0) {
                    dice.isRolling = false;
                    dice.scale = 1.0;
                    dice.rotation = 0;
                    dice.shakeX = 0; dice.shakeY = 0;
                    dice.currentFace = Math.floor(Math.random() * 6) + 1;
                    triggerSlamEffects(dice.x, dice.y, 'stone');
                }
            }

            // Update Premium Token Physics (Squash, Stretch & Arced Leaps)
            tokens.forEach(token => {
                if (token.isMoving) {
                    token.jumpProgress += dt * 2.5;
                    if (token.jumpProgress >= 1) {
                        token.currentX = token.targetX;
                        token.currentY = token.targetY;
                        token.isMoving = false;
                        token.jumpProgress = 0;
                        token.height = 0;
                        token.scaleX = 1.3; token.scaleY = 0.7; // Land squash impact
                        triggerSlamEffects(token.currentX, token.currentY, token.color);
                    } else {
                        // Smoothly glide position (lerp)
                        token.currentX = token.currentX + (token.targetX - token.currentX) * (dt * 10);
                        token.currentY = token.currentY + (token.targetY - token.currentY) * (dt * 10);
                        
                        // Parabolic height calculations (The Hop Arc)
                        token.height = Math.sin(token.jumpProgress * Math.PI) * 60;
                        token.scaleY = 1 + (token.height / 120); // Stretch in mid-air
                        token.scaleX = 1 - (token.height / 240);
                        token.shadowBlur = 8 + (token.height / 2); // Shadow blurs out as piece climbs
                    }
                } else {
                    // Settle back to 1.0 from squash phase smoothly
                    token.scaleX += (1 - token.scaleX) * (dt * 12);
                    token.scaleY += (1 - token.scaleY) * (dt * 12);
                }
            });

            // Update active particles
            particles.forEach((p, idx) => {
                p.update(dt);
                if (p.alpha <= 0) particles.splice(idx, 1);
            });

            draw();
            requestAnimationFrame(update);
        }

        // 7. RENDERING SYSTEM
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.save();
            ctx.translate(screenShake.x, screenShake.y); // Apply physical screen shake vectors

            if (gameState === 'splash') {
                // Background fills with solid brand yellow
                ctx.fillStyle = '#f7ca18';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // Render Brand Logo centered
                if (images.logo.complete) {
                    ctx.save();
                    ctx.globalAlpha = splashAlpha;
                    const logow = 300, logoh = 300;
                    ctx.drawImage(images.logo, canvas.width/2 - logow/2, canvas.height/2 - logoh/2 - 50, logow, logoh);
                    ctx.restore();
                }

                // Premium Dynamic Play Button Layout
                ctx.save();
                ctx.globalAlpha = splashAlpha;
                ctx.translate(canvas.width/2, canvas.height/2 + 180);
                ctx.scale(playButtonScale, playButtonScale);
                ctx.fillStyle = '#e74c3c';
                ctx.beginPath();
                ctx.roundRect(-120, -30, 240, 60, 30);
                ctx.fill();

                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 22px Arial';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText('PLAY LUDO', 0, 0);
                ctx.restore();

            } else if (gameState === 'playing') {
                // Draw Ludo Board Asset
                if (images.board.complete) {
                    ctx.drawImage(images.board, 0, 0, canvas.width, canvas.height);
                }

                // Draw Low-Size Blended Brand Logo Watermark Over Home Triangles
                if (images.logo.complete) {
                    ctx.save();
                    ctx.globalAlpha = 0.15; // Tint layer opacity blend
                    ctx.drawImage(images.logo, 320, 320, 160, 160);
                    ctx.restore();
                }

                // Draw Procedural Stone Dice 
                ctx.save();
                ctx.translate(dice.x + dice.shakeX, dice.y + dice.shakeY);
                ctx.rotate(dice.rotation * Math.PI / 180);
                ctx.scale(dice.scale, dice.scale);

                // Shadow system
                ctx.shadowColor = 'rgba(0, 0, 0, 0.5)';
                ctx.shadowBlur = dice.isRolling ? 25 : 12;
                ctx.shadowOffsetY = dice.isRolling ? 15 : 6;

                // Extraction Hack: Use central stone texture patch from image file dynamically
                if (images.dice.complete) {
                    ctx.beginPath();
                    ctx.roundRect(-dice.size/2, -dice.size/2, dice.size, dice.size, 16);
                    ctx.clip();
                    ctx.drawImage(images.dice, images.dice.width/2 - 50, images.dice.height/2 - 50, 100, 100, -dice.size/2, -dice.size/2, dice.size, dice.size);
                } else {
                    ctx.fillStyle = '#7f8c8d';
                    ctx.beginPath();
                    ctx.roundRect(-dice.size/2, -dice.size/2, dice.size, dice.size, 16);
                    ctx.fill();
                }
                ctx.shadowColor = 'transparent'; // Reset shadows

                // Draw programmatic face values
                drawDiceDots(dice.currentFace, dice.size);
                ctx.restore();

                // Draw premium heavy stone tokens
                tokens.forEach(token => {
                    ctx.save();
                    // Offset physical drop shadow according to jump heights
                    ctx.shadowColor = 'rgba(0, 0, 0, 0.6)';
                    ctx.shadowBlur = token.shadowBlur;
                    ctx.shadowOffsetX = 4 + (token.height / 6);
                    ctx.shadowOffsetY = 6 + (token.height / 3);

                    ctx.translate(token.currentX, token.currentY - token.height);
                    ctx.scale(token.scaleX, token.scaleY);

                    // Base gradient map for a distinct 3D carved finish
                    let grad = ctx.createRadialGradient(-5, -5, 2, 0, 0, 24);
                    grad.addColorStop(0, '#ffffff');
                    grad.addColorStop(0.2, token.color);
                    grad.addColorStop(1, '#111111');

                    ctx.fillStyle = grad;
                    ctx.beginPath();
                    ctx.arc(0, 0, 24, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.restore();
                });

                // Render transient active particles
                particles.forEach(p => p.draw());
            }

            ctx.restore();
        }

        // Helper function to dynamically output flat top-down carvings 
        function drawDiceDots(face, size) {
            ctx.fillStyle = '#111111';
            const radius = 6;
            const q = size / 4;

            const dots = {
                1: [[0, 0]],
                2: [[-q, -q], [q, q]],
                3: [[-q, -q], [0, 0], [q, q]],
                4: [[-q, -q], [q, -q], [-q, q], [q, q]],
                5: [[-q, -q], [q, -q], [0, 0], [-q, q], [q, q]],
                6: [[-q, -q], [q, -q], [-q, 0], [q, 0], [-q, q], [q, q]]
            };

            dots[face].forEach(pt => {
                ctx.beginPath();
                ctx.arc(pt[0], pt[1], radius, 0, Math.PI * 2);
                ctx.fill();
            });
        }

        // 8. INTERACTIVE INPUT HANDLERS
        canvas.addEventListener('click', (e) => {
            const rect = canvas.getBoundingClientRect();
            const clickX = (e.clientX - rect.left) * (canvas.width / rect.width);
            const clickY = (e.clientY - rect.top) * (canvas.height / rect.height);

            if (gameState === 'splash') {
                initAudio();
                // Check if hit bounds fall within play button constraints
                if (clickX > canvas.width/2 - 120 && clickX < canvas.width/2 + 120 &&
                    clickY > canvas.height/2 + 150 && clickY < canvas.height/2 + 210) {
                    splashStage = 'fade-out';
                    playSound('thud');
                }
            } else if (gameState === 'playing') {
                // Click Dice Area bounds check
                if (clickX > dice.x - dice.size && clickX < dice.x + dice.size &&
                    clickY > dice.y - dice.size && clickY < dice.y + dice.size && !dice.isRolling) {
                    dice.isRolling = true;
                    dice.rollTimer = 0.8; // Duration of dynamic tumbling action
                }
                
                // Demo click triggers a game token token movement jump forward
                tokens.forEach(token => {
                    if (clickX > token.currentX - 30 && clickX < token.currentX + 30 &&
                        clickY > token.currentY - 30 && clickY < token.currentY + 30 && !token.isMoving) {
                        token.isMoving = true;
                        token.targetX = token.currentX === 160 ? 400 : (token.currentX === 640 ? 400 : 160);
                        token.targetY = token.currentY === 160 ? 520 : (token.currentY === 160 ? 280 : 160);
                    }
                });
            }
        });

        // Start initialization loop routine
        requestAnimationFrame(update);
    </script>
</body>
</html>
